# Backend API base URL (must include /api). Used when running the app.
# - Emulator/simulator: use http://localhost:3000/api
# - Physical device: use your machine IP, e.g. http://192.168.1.100:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Optional app identifier sent as X-App-Id header
# EXPO_PUBLIC_APP_ID=default
